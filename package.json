{
  "name": "ganatrack",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:api": "turbo dev --filter=@ganatrack/api",
    "dev:web": "turbo dev --filter=@ganatrack/web",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "playwright": "^1.59.1",
    "pnpm": "^10.33.0",
    "turbo": "^2.3.0"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "supportedArchitectures": {
      "os": [
        "linux"
      ],
      "cpu": [
        "x64"
      ],
      "libc": [
        "glibc"
      ]
    }
  },
  "dependencies": {
    "@tailwindcss/oxide-linux-x64-gnu": "4.2.2"
  }
}
